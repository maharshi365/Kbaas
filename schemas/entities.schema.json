{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entities",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string"
      },
      "description": {
        "type": "string"
      },
      "examples": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "rules": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "invalidStrings": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "required": [
      "name",
      "description",
      "examples"
    ],
    "additionalProperties": false
  }
}
